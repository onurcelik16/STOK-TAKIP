    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.575.0",
    "morgan": "^1.10.1",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.48.2",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
