{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "outDir": "./dist",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "target": "ES2020",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowJs": true,
        "strict": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "app"
    ]
}