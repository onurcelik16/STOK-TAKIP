{
  "name": "stock-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:api": "tsx watch src/index.ts",
    "dev:web": "next dev -p 3001",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
